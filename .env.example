# Ghost Assistant Configuration

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Transcription Mode: "local" (whisper.cpp) or "cloud" (AWS Transcribe)
TRANSCRIPTION_MODE=local

# Bedrock Model ID
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-20250514-v1:0

# Whisper Model Path (relative to app data dir)
WHISPER_MODEL=models/ggml-small.en.bin

# Hotkeys (electron accelerator format)
HOTKEY_TOGGLE=CommandOrControl+Shift+G
HOTKEY_COLLAPSE=CommandOrControl+Shift+M
HOTKEY_QUICK_ASK=CommandOrControl+Shift+A
HOTKEY_CAPTURE_TOGGLE=CommandOrControl+Shift+R
HOTKEY_BOOKMARK=CommandOrControl+Shift+B

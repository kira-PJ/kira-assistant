{
  "name": "kira-assistant",
  "version": "0.2.0",
  "description": "K.I.R.A. — Knowledge, Insights & Response Assistant. Invisible AI call companion with real-time transcription and coaching.",
  "main": "dist/main/main/index.js",
  "author": {
    "name": "Kiira",
    "email": "kiira@kira-assistant.dev"
  },
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.main.json && electron .",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:linux": "electron-builder --linux",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1089.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.1089.0",
    "@aws-sdk/client-dynamodb": "^3.1090.0",
    "@aws-sdk/client-s3": "^3.1090.0",
    "@aws-sdk/client-transcribe-streaming": "^3.1089.0",
    "@aws-sdk/util-dynamodb": "^3.996.7",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.7",
    "@types/node": "^26.1.1",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "postcss": "^8.4.33",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^4.1.7",
    "typescript": "^5.3.3",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "build": {
    "appId": "com.kira-assistant.app",
    "productName": "K.I.R.A.",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "native/audio/build/Release/*.node",
      "package.json"
    ],
    "asarUnpack": [
      "native/audio/build/Release/*.node"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}

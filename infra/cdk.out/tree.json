ersion":"2012-10-17"},"policyName":"SearchHandlerServiceRoleDefaultPolicy154F2B3D","roles":[{"Ref":"SearchHandlerServiceRoleB55CE200"}]}}}}}}},"Resource":{"id":"Resource","path":"KiraStack/SearchHandler/Resource","constructInfo":{"fqn":"aws-cdk-lib.aws_lambda.CfnFunction","version":"2.261.0"},"attributes":{"aws:cdk:cloudformation:type":"AWS::Lambda::Function","aws:cdk:cloudformation:logicalId":"SearchHandler00CE2B50","aws:cdk:cloudformation:props":{"code":{"zipFile":"\n        const { DynamoDBClient, QueryCommand } = require('@aws-sdk/client-dynamodb');\n        const { unmarshall } = require('@aws-sdk/util-dynamodb');\n        const client = new DynamoDBClient({});\n\n        exports.handler = async (event) => {\n          const { userId, query } = JSON.parse(event.body || '{}');\n          if (!userId || !query) {\n            return { statusCode: 400, body: JSON.stringify({ error: 'userId and query required' }) };\n          }\n\n          // Query all calls for user then filter client-side (DynamoDB doesn't have FTS)\n          const result = await client.send(new QueryCommand({\n            TableName: process.env.CALLS_TABLE,\n            KeyConditionExpression: 'userId = :uid',\n            ExpressionAttributeValues: { ':uid': { S: userId } },\n          }));\n\n          const items = (result.Items || []).map(item => unmarshall(item));\n          const terms = query.toLowerCase().split(/\\s+/);\n\n          const matches = items.filter(item => {\n            const searchable = JSON.stringify(item).toLowerCase();\n            return terms.every(t => searchable.includes(t));\n          }).slice(0, 20);\n\n          return {\n            statusCode: 200,\n            headers: { 'Content-Type': 'application/json' },\n            body: JSON.stringify({ results: matches, total: matches.length }),\n          };\n        };\n      "},"environment":{"variables":{"CALLS_TABLE":{"Ref":"CallsTableD3962D26"}}},"functionName":"kira-search","handler":"index.handler","memorySize":256,"role":{"Fn::GetAtt":["SearchHandlerServiceRoleB55CE200","Arn"]},"runtime":"nodejs20.x","timeout":15}}}}},"ApiUrl":{"id":"ApiUrl","path":"KiraStack/ApiUrl","constructInfo":{"fqn":"aws-cdk-lib.CfnOutput","version":"2.261.0"}},"UserPoolId":{"id":"UserPoolId","path":"KiraStack/UserPoolId","constructInfo":{"fqn":"aws-cdk-lib.CfnOutput","version":"2.261.0"}},"UserPoolClientId":{"id":"UserPoolClientId","path":"KiraStack/UserPoolClientId","constructInfo":{"fqn":"aws-cdk-lib.CfnOutput","version":"2.261.0"}},"TranscriptsBucketName":{"id":"TranscriptsBucketName","path":"KiraStack/TranscriptsBucketName","constructInfo":{"fqn":"aws-cdk-lib.CfnOutput","version":"2.261.0"}},"DashboardUrl":{"id":"DashboardUrl","path":"KiraStack/DashboardUrl","constructInfo":{"fqn":"aws-cdk-lib.CfnOutput","version":"2.261.0"}},"DashboardBucketName":{"id":"DashboardBucketName","path":"KiraStack/DashboardBucketName","constructInfo":{"fqn":"aws-cdk-lib.CfnOutput","version":"2.261.0"}},"CDKMetadata":{"id":"CDKMetadata","path":"KiraStack/CDKMetadata","constructInfo":{"fqn":"constructs.Construct","version":"10.7.0"},"children":{"Default":{"id":"Default","path":"KiraStack/CDKMetadata/Default","constructInfo":{"fqn":"aws-cdk-lib.CfnResource","version":"2.261.0"}}}},"BootstrapVersion":{"id":"BootstrapVersion","path":"KiraStack/BootstrapVersion","constructInfo":{"fqn":"aws-cdk-lib.CfnParameter","version":"2.261.0"}},"CheckBootstrapVersion":{"id":"CheckBootstrapVersion","path":"KiraStack/CheckBootstrapVersion","constructInfo":{"fqn":"aws-cdk-lib.CfnRule","version":"2.261.0"}}}},"Tree":{"id":"Tree","path":"Tree","constructInfo":{"fqn":"constructs.Construct","version":"10.7.0"}}}}}